{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Polly": "Warning"
    }
  },
  "DatabaseConfiguration": {
    "Provider": "SqlServer",
    "ConnectionString": "Server=sql-server.lan; User ID=example; Password=strongpassword; Database=Dispatcher-Dev;TrustServerCertificate=true;Application Name=Dispatcher-Dev"
  },
  "GitHub": {
    "Token": "",
    "ApiBaseUrl": "https://api.github.com/",
    "PollIntervalSeconds": 60,
    "Filter": {
      "LabelFilter": ["AI-Work"],
      "NoWorkFilter": ["on-hold", "blocked"],
      "AllowedOwners": [],
      "ExcludedRepos": [],
      "MaxIssues": 10,
      "PullRequests": {
        "AdoptionRules": [
          { "Author": "dependabot[bot]", "BranchPrefix": "dependabot/", "DefaultPriority": "MEDIUM", "TimeoutHours": 24, "Priority": "SECURITY" },
          { "Author": "github-actions[bot]", "BranchPrefix": "depends/", "DefaultPriority": "MEDIUM", "TimeoutHours": 24, "Priority": "SECURITY" }
        ]
      }
    },
    "Scan": {
      "ScanIntervalSeconds": 3600
    }
  }
}

{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Database": {
    "ConnectionString": "Server=sql-server.lan; User ID=example; Password=strongpassword; Database=Dispatcher-Dev;TrustServerCertificate=true;Application Name=Dispatcher-Dev"
  },
  "GitHub": {
    "Token": "",
    "PollIntervalSeconds": 60,
    "Filter": {
      "LabelFilter": ["AI-Work"],
      "NoWorkFilter": ["on-hold", "blocked"],
      "AllowedOwners": [],
      "AllowedRepos": [],
      "ExcludedRepos": [],
      "MaxIssues": 10,
      "StuckDependabotTimeoutHours": 3,
      "PullRequests": {
        "AdoptionRules": [
          { "Author": "app/dependabot[bot]", "BranchPrefix": "dependabot/", "DefaultPriority": "MEDIUM", "TimeoutHours": 24, "Priority": "SECURITY" },
          { "Author": "app/github-actions[bot]", "BranchPrefix": "depends/", "DefaultPriority": "MEDIUM", "TimeoutHours": 24, "Priority": "SECURITY" }
        ]
      }
    },
    "Scan": {
      "ScanIntervalSeconds": 3600
    }
  }
}
